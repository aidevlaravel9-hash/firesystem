      "name": "Create Building",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer_id\": 1,\n  \"building_name\": \"Main Office Building\",\n  \"postcode\": \"380001\",\n  \"country_id\": 1,\n  \"state_id\": 5,\n  \"city_id\": 10,\n  \"address\": \"123 Business Park, Sector 5\",\n  \"landmark\": \"Near City Mall\",\n  \"status\": \"active\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/building/create_building",
          "host": ["{{base_url}}"],
          "path": ["api", "building", "create_building"]
        }
      },
      "response": []
